# Environment
NODE_ENV=production
PORT=3000

# Security
JWT_SECRET=replace_with_strong_random_string
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=info

# Backups / Migrations
BACKUP_RETENTION_DAYS=7
MIGRATIONS_DRY_RUN=0
# Optional: override DB path (leave empty in production)
# DB_PATH=

# Optional: app data dir override
# APP_DATA_DIR=
